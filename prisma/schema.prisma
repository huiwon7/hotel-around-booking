generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model RoomType {
  id          String   @id @default(uuid())
  code        String   @unique // hotel, terrace, villa
  nameKo      String   @map("name_ko")
  nameEn      String   @map("name_en")
  description String?
  maxGuests   Int      @map("max_guests")
  basePrice   Int      @map("base_price")
  totalCount  Int      @map("total_count")
  amenities   String?  @default("[]")
  images      String?  @default("[]")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  inventory    RoomInventory[]
  reservations Reservation[]
  pricing      SeasonalPricing[]

  @@map("room_types")
}

model Package {
  id          String   @id @default(uuid())
  code        String   @unique
  nameKo      String   @map("name_ko")
  nameEn      String   @map("name_en")
  description String?
  nights      Int
  basePrice   Int      @map("base_price")
  perNight    Int      @map("per_night")
  discountPct Int      @default(0) @map("discount_pct")
  features    String?  @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  reservations Reservation[]

  @@map("packages")
}

model RoomInventory {
  id            String    @id @default(uuid())
  roomTypeId    String    @map("room_type_id")
  date          DateTime
  totalRooms    Int       @map("total_rooms")
  bookedRooms   Int       @default(0) @map("booked_rooms")
  priceOverride Int?      @map("price_override")
  isClosed      Boolean   @default(false) @map("is_closed")
  pmsSyncedAt   DateTime? @map("pms_synced_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([roomTypeId, date])
  @@map("room_inventory")
}

model Guest {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  company   String?
  memo      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reservations Reservation[]

  @@map("guests")
}

model Reservation {
  id                 String   @id @default(uuid())
  reservationNo      String   @unique @map("reservation_no")
  guestId            String   @map("guest_id")
  roomTypeId         String   @map("room_type_id")
  packageId          String?  @map("package_id")
  checkIn            DateTime @map("check_in")
  checkOut           DateTime @map("check_out")
  nights             Int
  guestsCount        Int      @map("guests_count")
  totalPrice         Int      @map("total_price")
  status             String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, CHECKED_IN, CHECKED_OUT, NO_SHOW
  paymentStatus      String   @default("UNPAID") @map("payment_status") // UNPAID, PAID, REFUNDED
  paymentId          String?  @map("payment_id")
  pmsReservationId   String?  @map("pms_reservation_id")
  specialRequests    String?  @map("special_requests")
  source             String   @default("WEBSITE") // WEBSITE, ADMIN, PMS
  telegramNotified   Boolean  @default(false) @map("telegram_notified")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  guest    Guest    @relation(fields: [guestId], references: [id])
  roomType RoomType @relation(fields: [roomTypeId], references: [id])
  package  Package? @relation(fields: [packageId], references: [id])

  @@map("reservations")
}

model SeasonalPricing {
  id            String   @id @default(uuid())
  name          String
  roomTypeId    String   @map("room_type_id")
  dateFrom      DateTime @map("date_from")
  dateTo        DateTime @map("date_to")
  priceModifier Int      @map("price_modifier")
  modifierType  String   @default("PERCENTAGE") @map("modifier_type") // ABSOLUTE, PERCENTAGE
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@map("seasonal_pricing")
}

model PmsSyncLog {
  id           String    @id @default(uuid())
  syncType     String    @map("sync_type") // INVENTORY, RESERVATION, FULL
  direction    String    // TO_PMS, FROM_PMS
  status       String    // SUCCESS, FAILED, PARTIAL
  recordsCount Int       @default(0) @map("records_count")
  errorMessage String?   @map("error_message")
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  @@map("pms_sync_log")
}
